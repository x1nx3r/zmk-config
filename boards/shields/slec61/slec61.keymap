#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

/ {
    behaviors {
        mm_h: mm_h {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp H>, <&kp LEFT>;
            mods = <(MOD_LALT|MOD_RALT)>;
        };
        mm_j: mm_j {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp J>, <&kp DOWN>;
            mods = <(MOD_LALT|MOD_RALT)>;
        };
        mm_k: mm_k {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp K>, <&kp UP>;
            mods = <(MOD_LALT|MOD_RALT)>;
        };
        mm_l: mm_l {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp L>, <&kp RIGHT>;
            mods = <(MOD_LALT|MOD_RALT)>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&kp ESC   &kp N1    &kp N2   &kp N3   &kp N4   &kp N5   &kp N6   &kp N7   &kp N8   &kp N9    &kp N0   &kp MINUS &kp EQUAL &kp BSPC
&kp TAB     &kp Q     &kp W    &kp E    &kp R    &kp T    &kp Y    &kp U    &kp I    &kp O     &kp P    &kp LBKT  &kp RBKT  &kp BSLH
&kp CAPS      &kp A     &kp S    &kp D    &kp F    &kp G    &mm_h    &mm_j    &mm_k    &mm_l     &kp SEMI &kp SQT             &kp RET
&kp LSHFT       &kp Z     &kp X    &kp C    &kp V    &kp B    &kp N    &kp M    &kp COMMA &kp DOT  &kp FSLH  &kp RALT         &kp RSHFT
&kp LCTRL   &kp LGUI  &kp LALT                      &kp SPACE                        &kp RALT            &lt 1 K_APP &kp RCTRL
            >;
        };

        bt_layer {
            bindings = <
&kp GRAVE &bt BT_SEL 0 &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_SEL 3 &bt BT_SEL 4 &trans   &trans   &trans   &trans    &trans   &trans    &trans    &bt BT_CLR
&trans      &trans       &trans       &trans       &trans       &trans       &trans   &trans   &trans   &trans    &trans   &trans    &trans    &trans
&trans        &trans       &trans       &trans       &trans       &trans       &trans   &trans   &trans   &trans    &trans   &trans              &studio_unlock
&trans          &trans       &trans       &trans       &trans       &trans       &trans   &trans   &trans   &trans   &trans   &trans             &trans
&trans      &trans    &trans                            &trans                           &trans              &trans          &trans
            >;
        };
    };
};
